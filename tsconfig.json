{
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["bun"],
		"paths": {
			"lib/*": ["./lib/*"],
			"tests/*": ["./tests/*"]
		}
	},
	"exclude": ["node_modules", "out"]
}
